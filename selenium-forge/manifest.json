{
  "manifest_version": 3,
  "name": "SeleniumForge - Test Recorder & Generator",
  "version": "1.0.0",
  "description": "Record, playback, and export Selenium tests. Full Selenese command support, data-driven testing, control flow, and multi-framework export including Cucumber/Gherkin BDD.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "downloads",
    "contextMenus",
    "notifications",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "panel/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/recorder.js"],
      "css": ["content/recorder.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "side_panel": {
    "default_path": "panel/sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
